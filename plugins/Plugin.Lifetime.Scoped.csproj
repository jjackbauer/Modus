<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Plugin.Lifetime.Scoped</AssemblyName>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <ModusVersion>1.0.0</ModusVersion>
    <ModusCapabilities>Cap.Lifetime.Scoped</ModusCapabilities>
    <ModusOperations>Lifetime.Scoped.PrintId</ModusOperations>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="LifetimeOperationResult.cs" />
    <Compile Include="LifetimeOperationPayload.cs" />
    <Compile Include="ScopedLifetimePlugin.cs" />
    <ProjectReference Include="..\src\Modus.Core\Modus.Core.csproj" />
  </ItemGroup>

</Project>
